extends ../layout/index.pug

block contenido
  div(class="py-3")
    h1.text-4xl.my-10.font-extrabold.text-center Bienes
      span.font-normal Raices
    h2(class="text-center text-2xl")= pagina

    div.mt-8.mx-auto.max-w-md
      div.bg-white.py-8.px-4.shadow
        form.space-y-3(action="") 
          div
            label.block.text-sm.uppercase.text-gray-500.mb-2.font-bold(for="email") Email de Registro
            input#email.w-full.px-3.py-2.border.border-gray-300.rounded-md.placeholder-gray-400(placeholder="Tu email" type="email" name="email")
          div(class="flex items-center justify-between")
            a(class="text-gray-500 text-xs" href="/auth/login") ¿Ya tienes cuenta? Inicia Sesión
            a(class="text-gray-500 text-xs" href="/auth/registro") No tienes cuenta? Crea una

          div
            input(type="submit" value="Enviar Instrucciones" class="w-full bg-indigo-600 hover:bg-indigo-800 text-white font-bold py-3 cursor-pointer mt-3")